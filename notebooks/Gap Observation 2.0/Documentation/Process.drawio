                <mxCell id="40" value="&lt;b&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;Automate the Process&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="43" vertex="1">
