   "source": [
    "# Recompute predictability stats using the actual column structure in the provided DataFrame\n",
    "# Criteria: sufficient activity, consistency, and some streak memory\n",
    "\n",
    "# Total seen per indicator\n",
    "indicator_stats = temporal_features_df.groupby('indicator').agg(\n",
    "    total_seen=('seen', 'sum'),\n",
    "    total_days=('seen', 'count'),\n",
    "    max_seen_streak=('seen_streak', 'max'),\n",
    "    seen_ratio=('seen', 'mean')\n",
    ").reset_index()\n",
    "\n",
    "# Define predictability condition more clearly based on real columns\n",
    "indicator_stats['is_predictable'] = (\n",
    "    (indicator_stats['total_seen'] >= 5) &\n",
    "    (indicator_stats['seen_ratio'] >= 0.10) &\n",
    "    (indicator_stats['max_seen_streak'] >= 2)\n",
    ")\n",
    "\n",
    "# Merge back with main DataFrame\n",
    "df_with_tags = temporal_features_df.merge(indicator_stats[['indicator', 'is_predictable']], on='indicator', how='left')\n",
    "\n",
    "model_data = df_with_tags[df_with_tags['is_predictable'] == True]\n",
    "model_data"
   ]
  },
