    "import pandas as pd\n",
    "from sklearn.ensemble import GradientBoostingClassifier\n",
    "\n",
    "# === Parameters ===\n",
    "features = [\n",
    "    'observations', 'cumulative_seen', 'days_since_last_seen', 'seen_streak',\n",
    "    'rolling_seen_ratio_14d', 'rolling_seen_std_14d',\n",
    "    'high_activity_not_seen_ratio_14d', 'low_activity_seen_ratio_14d',\n",
    "    'seen_ratio_diff', 'obs_ratio_spike', 'recent_drop_flag'\n",
    "]\n",
    "prediction_date = pd.to_datetime(\"2025-04-28\")\n",
    "cutoff_date = prediction_date - pd.Timedelta(days=7)\n",
    "\n",
    "# === Training data: everything before cutoff\n",
    "train_data = model_data[model_data['date'] < cutoff_date].copy()\n",
    "X_train = train_data[features].fillna(0)\n",
    "y_train = train_data['seen']\n",
    "\n",
    "# === Prediction input: most recent record per indicator up to cutoff\n",
    "latest_snapshot = (\n",
    "    model_data[model_data['date'] <= cutoff_date]\n",
    "    .sort_values('date')\n",
    "    .groupby('indicator')\n",
    "    .tail(1)\n",
    "    .copy()\n",
    ")\n",
    "X_forecast = latest_snapshot[features].fillna(0)\n",
    "\n",
    "# === Train model\n",
    "model = GradientBoostingClassifier(\n",
    "    n_estimators=150,\n",
    "    learning_rate=0.05,\n",
    "    max_depth=4,\n",
    "    subsample=0.8,\n",
    "    random_state=42\n",
    ")\n",
    "model.fit(X_train, y_train)\n",
    "\n",
    "# === Predict soft vote score\n",
    "latest_snapshot['probability'] = model.predict_proba(X_forecast)[:, 1]\n",
    "\n",
    "# === Compute rule-based score\n",
    "rule_score = (\n",
    "    0.4 * (latest_snapshot['seen_streak_prev'] >= 4).astype(int) +\n",
    "    0.3 * (latest_snapshot['rolling_seen_ratio_14d'] > 0.85).astype(int) +\n",
    "    0.3 * (latest_snapshot['obs_ratio_spike'] > 1.1).astype(int)\n",
    ")\n",
    "soft_vote = 0.6 * latest_snapshot['probability'] + 0.4 * rule_score\n",
    "\n",
    "# === Apply secondary filters\n",
    "secondary_filter = (\n",
    "    (latest_snapshot['rolling_seen_ratio_14d'] > 0.7) &\n",
    "    (latest_snapshot['seen_streak_prev'] >= 2)\n",
    ")\n",
    "\n",
    "# === Final ensemble decision\n",
    "latest_snapshot['final_seen'] = ((soft_vote >= 0.55) & secondary_filter).astype(int)\n",
    "\n",
    "# === Output final forecasted indicators\n",
    "forecasted_indicators = latest_snapshot[latest_snapshot['final_seen'] == 1][['indicator']]\n",
    "print(f\"Forecasted indicators expected to be seen on {prediction_date.date()}:\")\n",
    "for ind in forecasted_indicators['indicator']:\n",
    "    print(\"-\", ind)\n"
